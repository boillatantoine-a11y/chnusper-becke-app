// api/save-subscription.js — Fonction Vercel (Node)
// Stocke un abonnement push dans un bin JSONBin dédié.
// Variables d'env Vercel requises : JSONBIN_KEY, SUBS_BIN_ID

const BIN = () => "https://api.jsonbin.io/v3/b/" + process.env.SUBS_BIN_ID;

async function readSubs() {
  const r = await fetch(BIN() + "/latest", {
    headers: { "X-Master-Key": process.env.JSONBIN_KEY }
  });
  if (!r.ok) return [];
  const j = await r.json();
  return (j.record && Array.isArray(j.record.subs)) ? j.record.subs : [];
}

async function writeSubs(subs) {
  await fetch(BIN(), {
    method: "PUT",
    headers: { "Content-Type": "application/json", "X-Master-Key": process.env.JSONBIN_KEY },
    body: JSON.stringify({ subs })
  });
}

export default async function handler(req, res) {
  if (req.method !== "POST") return res.status(405).json({ error: "POST only" });
  try {
    const { user, subscription } = req.body || {};
    if (!subscription || !subscription.endpoint) {
      return res.status(400).json({ error: "subscription manquante" });
    }
    const subs = await readSubs();
    // Dédoublonnage par endpoint
    const filtered = subs.filter(s => s.subscription.endpoint !== subscription.endpoint);
    filtered.push({ user: user || "?", subscription, ts: Date.now() });
    await writeSubs(filtered);
    return res.status(200).json({ ok: true, count: filtered.length });
  } catch (e) {
    return res.status(500).json({ error: String(e) });
  }
}
